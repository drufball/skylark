#!/usr/bin/env bash
# scripts/setup-tunnel — expose Skylark publicly over Cloudflare Tunnel, so
# you can reach it from a phone or laptop anywhere without opening a port on
# your router or putting anyone on a VPN. Deliberately NOT called from hoist:
# it needs your own Cloudflare account, a domain already in it, and a
# one-time browser login — none of which can be scripted around. Run it
# yourself whenever you're ready; idempotent, safe to re-run.
#
# Security note: only run this once real auth is in place (see
# hull/auth/zine.md) — this makes the ship reachable from the open internet,
# gated by whatever's actually enforcing login at that point.
set -euo pipefail
cd "$(dirname "$0")/.."

TUNNEL_NAME="skylark"

# This script's natural habitat is the terminal that JUST ran hoist — a shell
# older than the Homebrew install, whose PATH lacks brew's prefix (only new
# terminals pick it up from ~/.zprofile). Grab it before concluding anything
# is missing.
if ! command -v cloudflared >/dev/null 2>&1; then
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

if ! command -v cloudflared >/dev/null 2>&1; then
  echo "cloudflared isn't installed — run ./scripts/install-system-deps first (or ./scripts/hoist)."
  exit 1
fi

if [ ! -f "$HOME/.cloudflared/cert.pem" ]; then
  echo "Not logged into Cloudflare yet."
  read -rp "Run 'cloudflared tunnel login' now? This opens a browser. [Y/n] " reply
  case "$reply" in
    n | N | no | No)
      echo "Skipped — re-run this script once you're ready."
      exit 0
      ;;
  esac
  cloudflared tunnel login
fi

# Look up an existing tunnel's id by name — node instead of jq, since node's
# already a hard requirement and jq isn't installed by scripts/install-system-deps.
# An account with ZERO tunnels lists as JSON `null`, not `[]` (Go nil slice),
# so anything non-array reads as "no tunnels" rather than crashing.
tunnel_id_for() {
  cloudflared tunnel list -o json 2>/dev/null | node -e '
    let data;
    try {
      data = JSON.parse(require("fs").readFileSync(0, "utf8"));
    } catch {
      data = [];
    }
    if (!Array.isArray(data)) data = [];
    const t = data.find((t) => t.name === process.argv[1]);
    if (t) process.stdout.write(t.id);
  ' "$1"
}

TUNNEL_ID="$(tunnel_id_for "$TUNNEL_NAME")"
if [ -z "$TUNNEL_ID" ]; then
  echo "→ creating tunnel \"$TUNNEL_NAME\"…"
  cloudflared tunnel create "$TUNNEL_NAME"
  TUNNEL_ID="$(tunnel_id_for "$TUNNEL_NAME")"
else
  echo "  ✓ tunnel \"$TUNNEL_NAME\" already exists"
fi

read -rp "Hostname to route to this ship (e.g. skylark.yourdomain.com), blank to skip: " HOSTNAME
if [ -z "$HOSTNAME" ]; then
  echo "Skipped DNS routing — re-run this script once you have a domain ready."
  exit 0
fi

cloudflared tunnel route dns "$TUNNEL_NAME" "$HOSTNAME"

# Optionally expose the LLM gateway's admin UI on a second hostname, so keys
# and models can be managed from a phone or laptop anywhere. Safe to expose:
# both the UI login and every API route demand LITELLM_MASTER_KEY, which
# configure-env minted as a real secret before the gateway first booted.
echo
read -rp "Hostname for the LLM gateway UI (e.g. llm.yourdomain.com), blank to keep it localhost-only: " GW_HOSTNAME
if [ -n "$GW_HOSTNAME" ]; then
  cloudflared tunnel route dns "$TUNNEL_NAME" "$GW_HOSTNAME"
fi

CONFIG_DIR="$HOME/.cloudflared"
mkdir -p "$CONFIG_DIR"
{
  cat <<EOF
tunnel: ${TUNNEL_ID}
credentials-file: ${CONFIG_DIR}/${TUNNEL_ID}.json
ingress:
  - hostname: ${HOSTNAME}
    service: http://localhost:3000
EOF
  if [ -n "$GW_HOSTNAME" ]; then
    cat <<EOF
  - hostname: ${GW_HOSTNAME}
    service: http://localhost:4000
EOF
  fi
  echo "  - service: http_status:404"
} >"$CONFIG_DIR/config.yml"

# The service is a ROOT LaunchDaemon, and cloudflared-as-root never reads
# this user's ~/.cloudflared/config.yml — its search paths are root's home
# and /etc/cloudflared. Mirror the config there (every run, so hostname
# additions propagate); the credentials-file path inside still points into
# this user's ~/.cloudflared, which root can read.
echo "→ mirroring tunnel config to /etc/cloudflared for the root service (needs sudo)…"
sudo mkdir -p /etc/cloudflared
sudo cp "$CONFIG_DIR/config.yml" /etc/cloudflared/config.yml

# `service install` refuses to run twice, and re-running THIS script is the
# documented way to add the gateway hostname later — so on a re-run, restart
# the existing service to pick up the rewritten config instead.
if [ -f /Library/LaunchDaemons/com.cloudflare.cloudflared.plist ]; then
  echo "→ tunnel service already installed — restarting it with the new config…"
  sudo launchctl kickstart -k system/com.cloudflare.cloudflared
else
  echo "→ installing the tunnel as a system service…"
  sudo cloudflared service install
fi

if [ -n "$GW_HOSTNAME" ]; then
  # Point the Models page's "manage models & keys" link at the public UI
  # (gatewayUiUrl reads this; without it the link is localhost-only). Same
  # idempotent upsert configure-env uses.
  GW_URL="https://${GW_HOSTNAME}/ui"
  [ -f .env ] || touch .env
  if grep -q '^SKYLARK_GATEWAY_UI_URL=' .env; then
    tmp="$(mktemp)"
    awk -F= -v v="$GW_URL" 'BEGIN{OFS="="} $1=="SKYLARK_GATEWAY_UI_URL"{$0="SKYLARK_GATEWAY_UI_URL="v} {print}' .env >"$tmp"
    mv "$tmp" .env
  else
    printf 'SKYLARK_GATEWAY_UI_URL=%s\n' "$GW_URL" >>.env
  fi
  # The app reads .env at boot, so the running ship won't see the new link
  # until it restarts — kick the persistent service if it's installed.
  if launchctl print "gui/$(id -u)/com.skylark.serve" >/dev/null 2>&1; then
    echo "→ restarting the ship so the Models page picks up the public UI link…"
    launchctl kickstart -k "gui/$(id -u)/com.skylark.serve"
  fi
fi

echo "✓ tunnel ready — https://${HOSTNAME} should reach this ship."
if [ -n "$GW_HOSTNAME" ]; then
  echo "  Gateway UI:  https://${GW_HOSTNAME}/ui — log in as admin with the"
  echo "               master key (grep LITELLM_MASTER_KEY .env)."
fi
