#!/usr/bin/env bash
# scripts/serve — actually run the ship: Postgres + gateway, migrate, seed,
# then the dev server in the foreground. This is the ONE body both a plain
# terminal invocation and the launchd-managed persistent service (see
# scripts/install-launchd) run — so there's no separate "production path" to
# drift from what you'd run by hand. In Skylark, `npm run dev` IS production
# (small scale is the point — see CLAUDE.md).
set -euo pipefail
cd "$(dirname "$0")/.."

# Mint machine secrets before anything boots: the gateway encrypts stored
# provider keys with LITELLM_SALT_KEY, so it must be real BEFORE the first
# boot, not rotated in after. No-op once set; instant and non-interactive.
./scripts/configure-env

# Bring up Postgres and the LLM gateway, WAITING for health — gateway-up
# blocks on each service's healthcheck (and creates the gateway's `litellm`
# database ahead of its first boot), so migrate/seed below can't race a
# still-booting server (#u4ct). If Docker itself isn't running, sail anyway:
# the app degrades to "database: down" / "gateway: unreachable" rather than
# refusing to start.
if ./scripts/gateway-up; then
  # Migrate and seed the crew so a fresh ship boots with a resolvable actor —
  # currentActor() needs at least the operator aboard. Both are idempotent,
  # and best-effort: a hiccup here never blocks `npm run dev`.
  npm run db:migrate || echo "⚠ couldn't apply migrations — continuing anyway"
  npm run users seed || echo "⚠ couldn't seed the crew — continuing anyway"
else
  echo "⚠ couldn't start Postgres + gateway — is Docker running? continuing anyway"
fi

# Export the default model override so the dev server inherits it at spawn.
# DEFAULT_MODEL is read once when the agent module is imported, so the value
# must be in the environment before then; exporting here guarantees that
# regardless of when the framework loads .env. (CLIs get it from .env via
# --env-file; this is the dev-server path, since a child script can't set its
# parent's env.)
if [ -f .env ] && grep -q '^SKYLARK_DEFAULT_MODEL=' .env; then
  export "$(grep '^SKYLARK_DEFAULT_MODEL=' .env | tail -n1)"
fi

exec npm run dev
