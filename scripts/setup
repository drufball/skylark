#!/usr/bin/env bash
# Bootstrap a Skylark worktree. Safe to run any number of times, and shared by
# everything that needs a working tree: local clones, git worktrees, Claude Code
# sessions, and CI. (Bringing up the live database is hoist's job, not setup's —
# tests run on in-memory PGlite, so most environments never need Postgres.)
set -euo pipefail
cd "$(dirname "$0")/.."

echo "⚓ Skylark setup"

# Fail with directions, not "npm: command not found" — on a truly fresh
# machine the system deps (Node included) arrive via hoist, which runs
# install-system-deps BEFORE this script.
if ! command -v npm >/dev/null 2>&1; then
  echo "✗ npm isn't installed — run ./scripts/hoist, which installs system deps first."
  exit 1
fi

echo "→ installing dependencies"
if [ "${CI:-}" = "true" ]; then
  npm ci
else
  npm install
fi

echo "→ generating routes"
npm run generate-routes >/dev/null

# No .env is written here: the db client defaults to the local Postgres URL when
# DATABASE_URL is unset (src/hull/db/client.ts), so a fresh clone or cloud
# session just works. Real overrides live in your own .env — copied into local
# worktrees by .worktreeinclude, or set as env vars in cloud.

echo "✓ setup complete — \`npm run dev\` to sail (\`./scripts/hoist\` brings up Postgres too)."
