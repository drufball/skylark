#!/usr/bin/env bash
# scripts/configure-env — mints the machine secrets .env needs, with no
# prompts: the gateway master key (API auth + UI login), the salt key that
# encrypts provider keys stored in the gateway's database, and the invite
# code real signups need (see hull/auth/zine.md). LLM provider keys are NOT
# gathered here — add those in the gateway's admin UI
# (http://localhost:4000/ui), which stores them encrypted in Postgres.
# Already-set values are never touched, so re-running (hoist and serve both
# do) is a no-op once configured — which matters doubly for the salt key: it
# MUST never change once provider keys are stored, or they become
# undecryptable.
set -euo pipefail
cd "$(dirname "$0")/.."

if [ "${CI:-}" = "true" ]; then
  echo "→ skipping .env setup (CI)"
  exit 0
fi

[ -f .env ] || touch .env

# Idempotent upsert: replace an existing KEY=... line, or append if absent.
set_env() {
  local key="$1" value="$2"
  if grep -q "^${key}=" .env; then
    local tmp
    tmp="$(mktemp)"
    awk -F= -v k="$key" -v v="$value" 'BEGIN{OFS="="} $1==k{$0=k"="v} {print}' .env >"$tmp"
    mv "$tmp" .env
  else
    printf '%s=%s\n' "$key" "$value" >>.env
  fi
}

env_has() {
  grep -q "^${1}=.\+" .env 2>/dev/null
}

# `head -c` closing the pipe early sends tr a SIGPIPE; under this script's
# `pipefail` that reads as failure and set -e would abort before the value is
# ever saved. Isolate pipefail to the subshell computing $().
random_token() {
  set +o pipefail
  LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c "$1"
}

ensure_secret() {
  local key="$1" value="$2" label="$3"
  if env_has "$key"; then
    echo "  ✓ $label already set"
  else
    set_env "$key" "$value"
    echo "  ✓ $label generated"
  fi
}

echo "→ machine secrets (.env) — LLM provider keys go in the gateway UI, not here"
ensure_secret LITELLM_MASTER_KEY "sk-$(random_token 40)" "gateway master key (LITELLM_MASTER_KEY)"
ensure_secret LITELLM_SALT_KEY "sk-$(random_token 40)" "gateway salt key (LITELLM_SALT_KEY)"
ensure_secret SKYLARK_INVITE_CODE "$(random_token 12)" "invite code (SKYLARK_INVITE_CODE)"
echo "✓ .env ready"
