#!/usr/bin/env bash
# scripts/gateway-up — bring up the LLM gateway (and the Postgres it stores
# models/keys in), in the right order. The gateway keeps UI-added models and
# encrypted provider keys in its own `litellm` database inside the ship's
# Postgres container, but the postgres image only creates the app database —
# so `litellm` has to exist before the gateway boots and tries to migrate it.
# Idempotent; `npm run gateway:up` and scripts/serve both run it.
set -euo pipefail
cd "$(dirname "$0")/.."

docker compose up -d --wait db

# CREATE DATABASE has no IF NOT EXISTS — check first, then create.
if ! docker compose exec -T db psql -U postgres -tAc \
  "SELECT 1 FROM pg_database WHERE datname = 'litellm'" | grep -q 1; then
  docker compose exec -T db createdb -U postgres litellm
  echo "→ created the gateway's litellm database"
fi

docker compose up -d --wait litellm
