#!/usr/bin/env bash
# scripts/hoist — bring the ship up AND keep it up. Provisions a fresh
# machine (system deps, machine secrets in .env — LLM provider keys are
# added later in the gateway's admin UI, never gathered here), then hands
# off to a persistent service so the ship survives reboots and crashes
# without a terminal open. On macOS that's launchd (see scripts/install-launchd);
# elsewhere — a later issue — hoist just runs scripts/serve in the
# foreground, same as always.
#
# Public access (Cloudflare Tunnel) is a deliberately separate, manual step —
# see scripts/setup-tunnel — since it needs your own Cloudflare account/domain
# and a one-time browser login. hoist never blocks on it.
set -euo pipefail
cd "$(dirname "$0")/.."

# System deps FIRST: on a truly fresh machine nothing else can run — setup
# needs npm, and Node only arrives via install-system-deps (Homebrew).
if [ "$(uname)" = "Darwin" ]; then
  ./scripts/install-system-deps
  # install-system-deps is a child process, so a freshly-installed Homebrew
  # (and its node/gh) isn't on THIS shell's PATH yet — pick up its prefix so
  # the steps below can see them without a fresh terminal.
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

./scripts/setup

./scripts/configure-env

if [ "$(uname)" != "Darwin" ]; then
  echo "⚠ no persistent-service support yet outside macOS — running in the foreground."
  exec ./scripts/serve
fi

./scripts/install-launchd

echo "→ waiting for the service to come up…"
ready=0
for _ in $(seq 1 30); do
  if curl -fsS http://localhost:3000/status >/dev/null 2>&1; then
    ready=1
    break
  fi
  sleep 1
done

echo
if [ "$ready" = "1" ]; then
  echo "✓ Skylark is up at http://localhost:3000"
else
  echo "⚠ didn't respond within 30s — check the logs: ~/Library/Logs/skylark/serve.log"
fi
invite_code="$(grep '^SKYLARK_INVITE_CODE=' .env | tail -n1 | cut -d= -f2-)"
echo "  Runs as a persistent service — survives logout and reboot."
echo "  Logs:          ~/Library/Logs/skylark/serve.log"
echo "  Status:        launchctl print gui/$(id -u)/com.skylark.serve"
echo "  Public access: ./scripts/setup-tunnel (whenever you're ready)"
echo
echo "Next steps:"
echo "  1. Add an LLM provider key: http://localhost:4000/ui — log in as admin"
echo "     with the master key (grep LITELLM_MASTER_KEY .env), then add a model"
echo "     named claude-sonnet-5 (or set SKYLARK_DEFAULT_MODEL to your name)."
echo "  2. Sign up at http://localhost:3000/signup — invite code: ${invite_code:-<unset>}"
