#!/usr/bin/env bash
# scripts/commit-gate — PreToolUse hook (Bash). Before any `git add` or
# `git commit`, run `npm run check`; if it fails, block the call so nothing
# lands until the ship is sound. Registered in .claude/settings.json.
#
# Input:  the PreToolUse JSON on stdin — we only care about the Bash command.
# Output: exit 0 lets the command through; exit 2 blocks it and feeds the
#         message on stderr back to the agent to fix.
set -euo pipefail
cd "$(dirname "$0")/.."

# Local-dev guardrail only. In CI (GitHub Actions) the agentic reviews and
# weekly agents run with their own gates — never gate their commits here.
[ "${GITHUB_ACTIONS:-}" = "true" ] && exit 0

# Pull the Bash command out of the hook payload (empty if this isn't a Bash call).
command="$(node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{process.stdout.write((JSON.parse(s).tool_input||{}).command||"")}catch{}})')"

# Gate only git add / git commit — allowing global options before the verb
# (`git -C path add`, `git -c k=v commit`) and a leading separator
# (`… && git commit`). The trailing class keeps `add-foo`/`addition` out.
if ! printf '%s' "$command" | grep -Eq '(^|[[:space:];&|(])git([[:space:]]+(-[Cc][[:space:]]+[^[:space:]]+|-[^[:space:]]+))*[[:space:]]+(add|commit)([^[:alnum:]_-]|$)'; then
  exit 0
fi

echo "→ commit-gate: running \`npm run check\` before committing…" >&2
if output="$(npm run check 2>&1)"; then
  exit 0
fi

{
  printf '%s\n\n' "$output"
  echo "⚠ \`npm run check\` failed — fix every error above, then commit. (commit-gate)"
} >&2
exit 2
