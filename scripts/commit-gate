#!/usr/bin/env bash
# scripts/commit-gate — PreToolUse hook (Bash). Before any `git add` or
# `git commit`, run `npm run check`; if it fails, block the call so nothing
# lands until the ship is sound. Registered in .claude/settings.json.
#
# Input:  the PreToolUse JSON on stdin — we only care about the Bash command.
# Output: exit 0 lets the command through; exit 2 blocks it and feeds the
#         message on stderr back to the agent to fix.
set -euo pipefail
script_dir="$(cd "$(dirname "$0")" && pwd)"

# Local-dev guardrail only. In CI (GitHub Actions) the agentic reviews and
# weekly agents run with their own gates — never gate their commits here.
[ "${GITHUB_ACTIONS:-}" = "true" ] && exit 0

# Pull the Bash command AND the session's cwd out of the hook payload in one
# stdin read (empty command if this isn't a Bash call). The cwd matters: a
# worktree session must be gated on ITS tree, not the main checkout (#uvnm).
payload="$(node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{const p=JSON.parse(s);process.stdout.write(JSON.stringify({command:(p.tool_input||{}).command||"",cwd:p.cwd||""}))}catch{process.stdout.write("{\"command\":\"\",\"cwd\":\"\"}")}})')"
command="$(printf '%s' "$payload" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{process.stdout.write(JSON.parse(s).command)})')"
hook_cwd="$(printf '%s' "$payload" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{process.stdout.write(JSON.parse(s).cwd)})')"

# Run the check in the tree being committed (see scripts/gate-workdir).
cd "$("$script_dir/gate-workdir" "$hook_cwd")"

# Gate only git add / git commit — allowing global options before the verb
# (`git -C path add`, `git -c k=v commit`, quoted values with spaces like
# `git -c user.name="a b" commit`) and a leading separator (`… && git commit`).
# The \b boundaries keep `legit add`/`git addition` out. This is the SAME
# regex as isCommitCommand in src/hull/agent/extensions/build-gates/gates.ts
# (the agent-side mirror, where it is unit-tested) — keep the two in sync.
if ! printf '%s' "$command" | node -e "let s='';process.stdin.on('data',d=>s+=d).on('end',()=>{process.exit(/\bgit(?:\s+-\S+(?:\s+(?!-)(?:[^\s\"']|\"[^\"]*\"|'[^']*')+)?)*\s+(add|commit)\b/.test(s)?0:1)})"; then
  exit 0
fi

# Defensive: if this tree has no node_modules, install deps first. A worktree
# created by the orchestrator but never properly initialized (#m5qt) would
# otherwise crash on `npm run check` with ERR_MODULE_NOT_FOUND. We're already
# cd'd into the worktree (gate-workdir above), so install HERE, not in the
# main checkout like scripts/setup would.
if [ ! -d node_modules ]; then
  echo "→ commit-gate: node_modules missing, installing deps first..." >&2
  # Same npm CI uses (package.json's packageManager pin) as scripts/setup —
  # a mismatched ambient npm can write a lockfile CI's npm ci then rejects
  # (#iv1t). npm-cmd reads THIS worktree's package.json (we're already cd'd
  # into it via gate-workdir above).
  npm_cmd="$(./scripts/npm-cmd)"
  if [ "${CI:-}" = "true" ]; then
    if ! $npm_cmd ci >&2 2>&1; then
      {
        echo ""
        echo "⚠ npm ci failed — this worktree can't run npm commands. Fix it before committing. (commit-gate)"
      } >&2
      exit 2
    fi
  else
    if ! $npm_cmd install >&2 2>&1; then
      {
        echo ""
        echo "⚠ npm install failed — this worktree can't run npm commands. Fix it before committing. (commit-gate)"
      } >&2
      exit 2
    fi
  fi
  # Also generate routes, matching what scripts/setup does.
  npm run generate-routes >/dev/null 2>&1 || true
fi

echo "→ commit-gate: running \`npm run check\` before committing…" >&2
if output="$(npm run check 2>&1)"; then
  exit 0
fi

{
  printf '%s\n\n' "$output"
  echo "⚠ \`npm run check\` failed — fix every error above, then commit. (commit-gate)"
} >&2
exit 2
