# dependencies
node_modules/

# build output
.output/
.nitro/
dist/
.vite/
*.tsbuildinfo

# generated route tree — regenerated by `npm run generate-routes` (setup runs it)
src/routeTree.gen.ts

# secrets & local env
.env
.env.*
!.env.example

# local postgres data (the docker compose volume)
.pgdata/

# coverage reports — regenerated by `npm run coverage`
coverage/

# mutation testing (Stryker) — reports and scratch space, never committed
reports/
.stryker-tmp/

# smoke tests (Playwright) — run artifacts, never committed
test-results/
playwright-report/

# logs & OS cruft
*.log
.DS_Store
.eslintcache

# editor (personal, local)
.vscode/
.idea/

# Claude Code: keep the crew (.claude/agents) tracked; ignore local state & worktrees
.claude/settings.local.json
.claude/worktrees/
.worktrees/
worktrees/
# Playwright agent-CLI session artifacts (snapshots, console logs)
.playwright-cli/
