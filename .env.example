# The ship's database. Local dev points at the Postgres started by `npm run db:up`.
# Tests never use this — they run against in-memory PGlite, so they need no DB.
# This is the SUPERUSER connection: migrations and a few fixed system paths
# (the agent runtime, the orchestrators' reconcile) use it. The app itself
# connects as the non-superuser `app_user` so Row-Level Security applies by
# default — those credentials are derived from this URL (app_user / app_user,
# set by migration 0009).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/skylark

# Deployment-only: point the app at app_user with rotated credentials instead of
# deriving them from DATABASE_URL. Same database, non-superuser role. Leave unset
# for local dev.
# APP_DATABASE_URL=postgres://app_user:CHANGE_ME@localhost:5432/skylark

# Who captains this ship: the human operator's handle. The web UI acts as this
# user by default, and `npm run users seed` creates them. Unset -> "captain".
# SKYLARK_OPERATOR=captain

# The provider key(s) the LLM gateway uses. Every model call goes through the
# LiteLLM gateway (`npm run gateway:up`); litellm.config.yaml maps model names
# to providers and reads keys from these vars. Anthropic backs the defaults —
# get a key at https://console.anthropic.com. Add others (OPENAI_API_KEY,
# TOGETHERAI_API_KEY, FIREWORKS_AI_API_KEY, …) only if you route a model to
# that provider in litellm.config.yaml.
ANTHROPIC_API_KEY=sk-ant-...

# The default model a session boots with, by its gateway name (a model_name in
# litellm.config.yaml). Unset -> claude-sonnet-5.
# SKYLARK_DEFAULT_MODEL=claude-sonnet-5

# Where the gateway listens. Unset -> the docker-compose LiteLLM container at
# http://localhost:4000. Point elsewhere to use a shared or remote gateway.
# SKYLARK_GATEWAY_URL=http://localhost:4000

# The key the gateway requires and the app sends — shared via this one var.
# Unset -> a fixed local default (fine for a localhost-only gateway); set a
# real secret if the gateway is ever reachable beyond this machine.
# LITELLM_MASTER_KEY=sk-...

# Tune the window/output assumed for gateway models (they drive compaction and
# the output cap). Defaults suit the Claude Sonnet class; shrink them if you
# route the default model to a small local server.
# SKYLARK_MODEL_CONTEXT_WINDOW=200000
# SKYLARK_MODEL_MAX_TOKENS=32768
