# The ship's database. Local dev points at the Postgres started by `npm run db:up`.
# Tests never use this — they run against in-memory PGlite, so they need no DB.
# This is the SUPERUSER connection: migrations and a few fixed system paths
# (the agent runtime, the orchestrators' reconcile) use it. The app itself
# connects as the non-superuser `app_user` so Row-Level Security applies by
# default — those credentials are derived from this URL (app_user / app_user,
# set by migration 0009).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/skylark

# Deployment-only: point the app at app_user with rotated credentials instead of
# deriving them from DATABASE_URL. Same database, non-superuser role. Leave unset
# for local dev.
# APP_DATABASE_URL=postgres://app_user:CHANGE_ME@localhost:5432/skylark

# Who captains this ship: the human operator's handle. `npm run users seed`
# creates them (passwordless — sign up at /signup with this same handle, using
# SKYLARK_INVITE_CODE below, to claim it); CLI/agent processes fall back to
# this identity when SKYLARK_ACTOR isn't set. Unset -> "captain".
# SKYLARK_OPERATOR=captain

# The secret you hand out to let someone create a real account at /signup —
# you and whoever else you invite. Unset means signups are disabled (fails
# closed). Not needed to log in once an account exists, only to create one.
# SKYLARK_INVITE_CODE=

# LLM provider keys do NOT live here. Every model call goes through the
# LiteLLM gateway (`npm run gateway:up`); add provider keys and models in its
# admin UI at http://localhost:4000/ui — log in as `admin` with the
# LITELLM_MASTER_KEY below — and they're stored encrypted in the gateway's
# own database. A fresh ship needs a model named claude-sonnet-5 there (or
# set SKYLARK_DEFAULT_MODEL to whatever name you choose).

# The default model a session boots with, by its gateway name (a model you
# added in the gateway UI). Unset -> claude-sonnet-5.
# SKYLARK_DEFAULT_MODEL=claude-sonnet-5

# Where the gateway listens. Unset -> the docker-compose LiteLLM container at
# http://localhost:4000. Point elsewhere to use a shared or remote gateway.
# SKYLARK_GATEWAY_URL=http://localhost:4000

# Where BROWSERS reach the gateway's admin UI — the Models page's "manage
# models & keys" link. Unset -> derived from the gateway URL (localhost-only).
# scripts/setup-tunnel sets this when you route a public hostname to the
# gateway (the app itself keeps calling the gateway at SKYLARK_GATEWAY_URL).
# SKYLARK_GATEWAY_UI_URL=https://llm.yourdomain.com/ui

# The key the gateway requires and the app sends — shared via this one var —
# and the gateway UI login (`admin` / this key). scripts/configure-env (run
# by hoist and serve) generates a real secret when unset in .env; the fixed
# fallback is only fit for a localhost-only gateway on a dev clone.
# LITELLM_MASTER_KEY=sk-...

# Encrypts provider keys at rest in the gateway's database. Also generated by
# scripts/configure-env. NEVER change it once keys are stored — they'd become
# undecryptable and need re-adding in the gateway UI.
# LITELLM_SALT_KEY=sk-...

# Tune the window/output assumed for gateway models (they drive compaction and
# the output cap). Defaults suit the Claude Sonnet class; shrink them if you
# route the default model to a small local server.
# SKYLARK_MODEL_CONTEXT_WINDOW=200000
# SKYLARK_MODEL_MAX_TOKENS=32768
