# The ship's database. Local dev points at the Postgres started by `npm run db:up`.
# Tests never use this — they run against in-memory PGlite, so they need no DB.
# This is the SUPERUSER connection: migrations and a few fixed system paths
# (the agent runtime, the orchestrators' reconcile) use it. The app itself
# connects as the non-superuser `app_user` so Row-Level Security applies by
# default — those credentials are derived from this URL (app_user / app_user,
# set by migration 0009).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/skylark

# Deployment-only: point the app at app_user with rotated credentials instead of
# deriving them from DATABASE_URL. Same database, non-superuser role. Leave unset
# for local dev.
# APP_DATABASE_URL=postgres://app_user:CHANGE_ME@localhost:5432/skylark

# The default model a session boots with. Skylark is local-first: `./scripts/hoist`
# auto-selects an Ollama model that fits this machine and writes it here, so a
# fresh clone runs with no API key. Override to pin any model, local or hosted —
# e.g. SKYLARK_DEFAULT_MODEL=anthropic/claude-sonnet-4-5. Unset → a small local
# model (ollama/qwen3:8b).
# SKYLARK_DEFAULT_MODEL=ollama/qwen3-coder:30b

# Where the local Ollama server listens. Defaults to 127.0.0.1:11434; set this to
# point at Ollama on another host (e.g. a GPU box). OLLAMA_BASE_URL (a full …/v1
# URL) overrides it if you need the exact endpoint.
# OLLAMA_HOST=127.0.0.1:11434

# Optional — only needed to use hosted models. Set the key for whichever provider
# you point SKYLARK_DEFAULT_MODEL (or a profile's model) at; the pi.dev SDK reads
# these from the environment. Get a Claude key at https://console.anthropic.com.
# ANTHROPIC_API_KEY=sk-ant-...
