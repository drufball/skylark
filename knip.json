{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/router.tsx",
    "src/routes/**/*.{ts,tsx}",
    "src/hull/**/cli.ts",
    "src/hull/agent/extensions/build-gates/index.ts",
    "e2e/**/*.ts",
    "test-excludes.mjs",
    "scripts/*.mjs"
  ],
  "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts", "scripts/*.mjs"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "@tailwindcss/typography",
    "@stryker-mutator/api"
  ]
}
